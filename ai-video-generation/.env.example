# App
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/videogen

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Storage (S3-compatible; use local path for dev)
STORAGE_BACKEND=local          # local | s3
LOCAL_STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
S3_BUCKET=videogen-outputs
S3_ENDPOINT_URL=               # Cloudflare R2: https://xxx.r2.cloudflarestorage.com

# AI APIs
OPENAI_API_KEY=sk-...
FAL_KEY=...
REPLICATE_API_TOKEN=r8_...
RUNWAYML_API_SECRET=...
KLING_API_KEY=...
ELEVENLABS_API_KEY=...
FASHN_API_KEY=...

# Pipeline defaults
DEFAULT_VIDEO_MODEL=kling       # kling | runway | wan
MOCK=false
